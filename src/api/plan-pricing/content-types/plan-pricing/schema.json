{
  "kind": "collectionType",
  "collectionName": "plan_pricings",
  "info": {
    "singularName": "plan-pricing",
    "pluralName": "plan-pricings",
    "displayName": "PlanPricing"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "billingCycle": {
      "type": "enumeration",
      "required": true,
      "default": "monthly",
      "enum": [
        "monthly",
        "quarterly",
        "half_yearly",
        "annual"
      ]
    },
    "discountText": {
      "type": "string"
    },
    "pricing_plans": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::pricing-plan.pricing-plan"
    }
  }
}
